  "item": [
    {
      "name": "Crear empleado",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.test(\"Empleado creado correctamente\", () => {",
              "  pm.expect(jsonData).to.have.property(\"id\");",
              "  pm.expect(jsonData.firstName).to.eql(\"John\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"{{employeeId}}\",\n  \"username\": \"jdoe\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"dependants\": 2,\n  \"salary\": 2000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Employees",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Employees"
          ]
        }
